{
  "manifest_version": 2,
  "name": "Hammerspoon Tab Switcher",
  "version": "1.0.0",
  "description": "Syncs browser tabs to Hammerspoon for keyboard-driven switching.",
  "permissions": ["tabs", "windows", "ws://localhost/*"],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hammerspoon-tabs@local",
      "strict_min_version": "109.0"
    }
  }
}
