[init]
  defaultBranch = main
[user]
	name = Tolu A.
  email = tolu@adesegha.ca
	signingkey = /home/toluadesegha/.ssh/id_ed25519.pub
[commit]
	gpgsign = true
[gpg]
	format = ssh
[pull]
	rebase = true
[core]
	editor = nvim
[push]
	autoSetupRemote = true
[alias]
  a = add
  b = branch
  c = commit
  ca = commit -a --amend --no-edit
  d = diff
  l = log
  m = merge
  ms = merge --squash
  o = checkout
  pl = pull
  ps = push
  rh = reset --hard
  r = restore
  s = status
  f = fetch
  sw = switch
  st = stash
  rb = rebase

[includeIf "gitdir:~/ds/"]
  path = ~/.gitconfig-ds
