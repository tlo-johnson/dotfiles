[init]
  defaultBranch = main
[user]
	name = Tolu A.
[pull]
	rebase = true
[core]
	editor = nvim
[push]
	autoSetupRemote = true
[alias]
  a = add
  b = branch
  c = commit
  ca = commit -a --amend --no-edit
  d = diff -w
  l = log
  m = merge
  ms = merge --squash
  o = checkout
  pl = pull
  ps = push
  rh = reset --hard
  r = restore
  s = status
  f = fetch
  sw = switch
  st = stash
  rb = rebase

[include]
  path = ~/.gitconfig.specific
