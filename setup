#!/usr/bin/env zsh
set -e

DOTFILES="$(cd "$(dirname "$0")" && pwd)"

# Detect OS
case "$OSTYPE" in
  darwin*) OS=mac ;;
  linux*)  OS=linux ;;
  *) echo "Unsupported OS: $OSTYPE" >&2; exit 1 ;;
esac
echo "==> Detected OS: $OS"

# Symlink helper. Skips real files/dirs (so nothing is clobbered), but always
# refreshes an existing symlink — removing it first avoids the ln -sf footgun
# where linking over a symlinked directory nests the link inside it.
link() {
  local src="$1" dst="$2"
  mkdir -p "$(dirname "$dst")"
  if [ -e "$dst" ] && [ ! -L "$dst" ]; then
    echo "    SKIP $dst (exists and is not a symlink — move it manually)"
    return
  fi
  [ -L "$dst" ] && rm "$dst"
  ln -s "$src" "$dst"
  echo "    $dst -> $src"
}

# ---- Package installation ----
if [[ "$OS" == "mac" ]]; then
  echo "==> Installing Homebrew packages..."
  if ! command -v brew &>/dev/null; then
    echo "    Homebrew not found. Installing..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi
  brew bundle --file="$DOTFILES/Brewfile"

  echo "==> Configuring jenv..."
  eval "$(jenv init -)" 2>/dev/null || true
  jenv enable-plugin export 2>/dev/null || true
else
  echo "==> Installing apt packages..."
  sudo apt update
  sudo apt install -y \
    git neovim tmux ripgrep jq wget tree dos2unix fzf \
    build-essential curl unzip
  # jj, node, and bun are not in the default apt repos — see manual steps below.
fi

# ---- Symlinks (portable, both OSes) ----
echo "==> Creating symlinks..."
link "$DOTFILES/.zshrc"     "$HOME/.zshrc"
link "$DOTFILES/.zprofile"  "$HOME/.zprofile"
link "$DOTFILES/.gitconfig" "$HOME/.gitconfig"
link "$DOTFILES/.tmux.conf" "$HOME/.tmux.conf"
link "$DOTFILES/nvim"       "$HOME/.config/nvim"

# OS-specific shell variants (sourced by .zshrc / .zprofile via $OSTYPE)
link "$DOTFILES/.zshrc.$OS"    "$HOME/.zshrc.$OS"
link "$DOTFILES/.zprofile.$OS" "$HOME/.zprofile.$OS"

# Bootstrap machine-specific git config (email + commit signing) from template
if [[ ! -e "$HOME/.gitconfig.specific" ]]; then
  cp "$DOTFILES/.gitconfig.specific.template" "$HOME/.gitconfig.specific"
  echo "    created ~/.gitconfig.specific from template (edit: email + signing key)"
fi

# ---- macOS-only GUI app configs ----
if [[ "$OS" == "mac" ]]; then
  link "$DOTFILES/ghostty"        "$HOME/.config/ghostty"
  link "$DOTFILES/hammerspoon"    "$HOME/.hammerspoon"
  mkdir -p "$HOME/.config/karabiner"
  link "$DOTFILES/karabiner.json" "$HOME/.config/karabiner/karabiner.json"
fi

# ---- Manual steps ----
echo ""
echo "==> Done. A few manual steps remain:"
echo "    * Edit ~/.gitconfig.specific (email + 1Password signing key)"
if [[ "$OS" == "mac" ]]; then
  echo "    1. Open 1Password > Settings > Developer > enable SSH agent"
  echo "    2. Open Hammerspoon > grant Accessibility permission > enable 'Launch at Login'"
  echo "    3. Open Karabiner-Elements and enable it"
  echo "    4. Import vimium-options.json in the Vimium browser extension"
  echo "    5. Sign in to 1Password CLI: 'op signin'"
  echo "    6. System Settings > Desktop & Dock > Mission Control:"
  echo "       - Uncheck 'Automatically rearrange Spaces based on most recent use'"
  echo "       - Check 'Displays have separate Spaces'"
  echo "    7. Create ~/.config/tlo/projects/dirs with directories to index"
  echo "    8. Install JDKs (e.g. brew install openjdk@17 openjdk@21), then:"
  echo "       jenv add /opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home"
  echo "       jenv add /opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home"
  echo "       jenv global 21"
else
  echo "    1. Install jj (jujutsu): cargo install --locked jj-cli  (or download a release binary)"
  echo "    2. Install node + bun if needed: 'sudo apt install nodejs npm' and 'curl -fsSL https://bun.sh/install | bash'"
  echo "    3. Configure SSH agent / commit signing in ~/.zprofile.linux and ~/.gitconfig.specific"
  echo "       (e.g. bridge to the 1Password app on Windows, or use a local ssh-agent)"
fi
